# ============================================================
# FreeAPPractice - SvelteKit Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Database
DATABASE_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/freeappractice

# Authentication
JWT_SECRET=your_jwt_secret_here_min_32_chars

# OpenAI (question generation + tutor)
OPEN_AI_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1

# Email (Resend)
RESEND_API_KEY=re_...
RESEND_FROM=Free AP Practice <noreply@freeappractice.org>

# AWS S3 / compatible storage
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
AWS_S3_BUCKET=freeappractice-questions
# Optional: custom endpoint (MinIO / R2 / Wasabi)
# AWS_S3_ENDPOINT=https://...
# AWS_S3_FORCE_PATH_STYLE=true

# App URLs
PUBLIC_BASE_URL=https://freeappractice.org

# Rate limiting (optional — defaults shown)
# API_RATE_LIMIT_WINDOW_MS=900000
# API_RATE_LIMIT_MAX=500
