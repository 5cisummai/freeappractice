# ============================================================
# FreeAPPractice - SvelteKit Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Database
DATABASE_URI=mongodb+srv://...

# Better Auth (required)
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=your_better_auth_secret_min_32_chars
BETTER_AUTH_URL=http://localhost:5173
# Optional: comma-separated Better Auth user IDs that should have admin access.
# Use authUsers.id values, not email addresses.
# BETTER_AUTH_ADMIN_USER_IDS=

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# OpenAI (question generation + tutor)
OPEN_AI_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
# GENERATION_MODEL=gpt-5.4-mini
# TUTOR_MODEL=gpt-4.1-mini

# Written-response grading model (feature on/off is the `frq-practice` Vercel Flag)
# FRQ_GRADING_MODEL=gpt-5.4-mini

# Deferred question-quality review (observational only; never affects serving)
# Shared bearer token used by `bun run quality` against the admin API.
QUESTION_QUALITY_ADMIN_TOKEN=replace_with_a_long_random_secret
# Leave false until a held-out human eval passes 95% Good precision and 90% agreement.
QUESTION_QUALITY_AGENT_CALIBRATED=false
# QUESTION_QUALITY_MODEL=gpt-5.6-luna
# QUESTION_QUALITY_REASONING_EFFORT=medium
# Set all three only after the bake-off and AP-specialist signoff. They must match at runtime.
# QUESTION_QUALITY_CALIBRATED_MODEL=gpt-5.6-luna
# QUESTION_QUALITY_CALIBRATED_RUBRIC=ap-quality-v2
# QUESTION_QUALITY_CALIBRATED_REASONING_EFFORT=medium
# QUESTION_QUALITY_CONFIDENCE_THRESHOLD=0.85
# Hosted web search is required for real AP courses; source URLs are retained for audit.
# QUESTION_QUALITY_WEB_SEARCH_CONTEXT_SIZE=high
# QUESTION_QUALITY_BATCH_SIZE=100
# QUESTION_QUALITY_MAX_QUEUED_TOKENS=250000
# Batch prices stay configurable so cost previews can be updated without a release.
# QUESTION_QUALITY_BATCH_INPUT_USD_PER_MILLION=0.625
# QUESTION_QUALITY_BATCH_OUTPUT_USD_PER_MILLION=3.75
# QUESTION_QUALITY_BASE_URL=https://example.com

# Email (Resend)
RESEND_API_KEY=re_...
RESEND_FROM=Example <noreply@example.com>

# AWS S3 / compatible storage (private bucket — question batches, etc.)
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
# Optional: temporary / assumed-role credentials
# AWS_SESSION_TOKEN=...
AWS_REGION=auto
AWS_S3_BUCKET=your_private_bucket_name

# Vercel Cron (production). Vercel sends Authorization: Bearer <CRON_SECRET>
# when invoking scheduled jobs. Generate: openssl rand -base64 32
# CRON_SECRET=

# App URLs
PUBLIC_BASE_URL=https://example.com

# PostHog (optional analytics — only loads after user consent)
PUBLIC_POSTHOG_PROJECT_TOKEN=phc_...
PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# GitHub Issues (bug reports)
# Fine-grained token scoped to 5cisummai/freeappractice with Issues: Read & Write
GITHUB_BUG_REPORT_TOKEN=github_pat_...

# CRON_SECRET= # Bearer token for /api/cron/* routes
# Pool fill knobs live in src/lib/questions/pool-constants.ts (not env).

# Vercel Flags (https://vercel.com/docs/flags)
# FLAGS_SECRET: encrypts Flags Explorer overrides + authenticates
# /.well-known/vercel/flags discovery. Required for Toolbar overrides.
# Generate: node -e "console.log(crypto.randomBytes(32).toString('base64url'))"
# Set in Vercel for Development / Preview / Production, then: vercel env pull
# FLAGS_SECRET=
#
# FLAGS: SDK key for @flags-sdk/vercel (auto-injected on Vercel when you
# create/promote flags). Locally available after vercel env pull.
# FLAGS=

PUBLIC_DESMOS_API_KEY=your_desmos_api_key_here
