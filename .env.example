# ============================================================
# FreeAPPractice - SvelteKit Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Database
DATABASE_URI=mongodb+srv://...

# Better Auth (required)
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=your_better_auth_secret_min_32_chars
BETTER_AUTH_URL=http://localhost:5173

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# OpenAI (question generation + tutor)
OPEN_AI_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1

# Email (Resend)
RESEND_API_KEY=re_...
RESEND_FROM=Example <noreply@example.com>

# AWS S3 / compatible storage (private bucket — question batches, etc.)
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
# Optional: temporary / assumed-role credentials
# AWS_SESSION_TOKEN=...
AWS_REGION=auto
AWS_S3_BUCKET=your_private_bucket_name

# Cloudflare R2 — public assets bucket (marketing / page images)
# Enable public access in Cloudflare R2, then set the bucket's public URL here.
PUBLIC_R2_ASSETS_URL=https://pub-xxxxxxxx.r2.dev
R2_PUBLIC_BUCKET=your_public_bucket_name
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# R2_REGION=auto
# R2_FORCE_PATH_STYLE=true

# Admin-only: POST /api/admin/questions/batch-analyze (S3 question batch + analysis)
# Send header X-Questions-Admin-Secret with this exact value (use a long random string)
# QUESTIONS_S3_ADMIN_SECRET=

# App URLs
PUBLIC_BASE_URL=https://example.com

# GitHub Issues (bug reports)
# Fine-grained token scoped to 5cisummai/freeappractice with Issues: Read & Write
GITHUB_BUG_REPORT_TOKEN=github_pat_...

# Question cache (MongoDB pool + serverless miss coordination)
# CACHE_POOL_SIZE=5
# CACHE_MISS_LOCK_TTL_MS=120000
# CACHE_MISS_FOLLOWER_MAX_WAIT_MS=45000

# Rate limiting (optional - defaults shown)
# API_RATE_LIMIT_WINDOW_MS=900000
# API_RATE_LIMIT_MAX=500

# Maintenance mode (set true during production auth migration cutover)
# MAINTENANCE_MODE=false

PUBLIC_DESMOS_API_KEY=your_desmos_api_key_here
