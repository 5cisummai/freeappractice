# ============================================================
# FreeAPPractice - SvelteKit Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Database
DATABASE_URI=mongodb+srv://...

# Authentication
JWT_SECRET=your_jwt_secret_here_min_32_chars

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# OpenAI (question generation + tutor)
OPEN_AI_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1

# Email (Resend)
RESEND_API_KEY=re_...
RESEND_FROM=Example <noreply@example.com>

# AWS S3 / compatible storage
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
AWS_S3_BUCKET=your_bucket_name
# Optional: custom endpoint (MinIO / R2 / Wasabi)
# AWS_S3_ENDPOINT=https://...
# AWS_S3_FORCE_PATH_STYLE=true

# App URLs
PUBLIC_BASE_URL=https://example.com

# GitHub Issues (bug reports)
# Fine-grained token scoped to 5cisummai/freeappractice with Issues: Read & Write
GITHUB_BUG_REPORT_TOKEN=github_pat_...

# Rate limiting (optional - defaults shown)
# API_RATE_LIMIT_WINDOW_MS=900000
# API_RATE_LIMIT_MAX=500

PUBLIC_DESMOS_API_KEY=your_desmos_api_key_here
