## Application
NODE_ENV=production
PORT=3000
LOG_LEVEL=info
PUBLIC_BASE_URL=https://freeappractice.org


#  Environment Configuration File
OPEN_AI_KEY=

# MongoDB Logging Configuration (optional)
DATABASE_URI=

JWT_SECRET=

## AWS S3 
# Required region for S3 operations, e.g. us-east-1
AWS_REGION=
# Default bucket name for uploads/downloads
AWS_S3_BUCKET=
# Optional: custom endpoint (MinIO/Cloudflare R2). Leave empty for AWS S3.
AWS_S3_ENDPOINT=
# Optional: set to 'true' for path-style access with custom endpoints
AWS_S3_FORCE_PATH_STYLE=false

# AWS Credentials
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Resend email service and Ttsting email
RESEND_API_KEY =
TEST_EMAIL = 
